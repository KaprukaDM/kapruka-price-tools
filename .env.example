# Copy to .env and fill in with your ROTATED keys. Never commit .env.

# OpenAI API key for the match-scoring step.
OPENAI_API_KEY=

# Model for match scoring. gpt-4o-mini (cheap, good) or gpt-4o (more accurate).
MATCH_MODEL=gpt-4o-mini

# SERP provider. Leave SERP_PROVIDER as "auto" to detect from key length
# (64 hex chars -> serpapi, otherwise serper), or set explicitly: serpapi | serper.
SERP_PROVIDER=auto
SERP_API_KEY=

# Optional HTTP(S) proxy (e.g. a Sri-Lankan-exit proxy) to force LKR pricing.
# Leave blank to scrape directly. Example: http://user:pass@host:port
SCRAPE_PROXY=

# Server port
PORT=3000

# Optional: Supabase/Postgres connection string for persistent storage.
# Project Settings -> Database -> Connection string -> URI (pooled, port 6543).
# Leave blank to use a local SQLite file (data/price-tools.db) for development.
# DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres
DATABASE_URL=
